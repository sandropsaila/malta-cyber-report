{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/lock.html" },
    { "src": "/index", "dest": "/lock.html" },
    { "src": "/lock.html", "dest": "/lock.html" },
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
